# Feishu/Lark document sync
LARK_WIKI_ROOT_TOKEN=replace-me
LARK_WIKI_BASE_URL=https://your-tenant.feishu.cn/wiki/
LARK_SYNC_OUTDIR=local-data/wiki-sync

# Feishu chat crawler
FEISHU_MESSENGER_URL=https://your-tenant.feishu.cn/next/messenger/
FEISHU_COOKIES_FILE=local-data/feishu-cookies.json
FEISHU_CDP_CLIENT=/path/to/cdp-client.mjs
FEISHU_TARGET_CHAT_NAME=your support group name
FEISHU_MAX_THREADS=80

# Optional DOM selector overrides. Feishu/Lark UI changes by tenant, language, and release channel.
FEISHU_CHAT_LIST_ITEM_SELECTOR=.feed-main-list [role="listitem"], .feed-main-list .feed-card, .a11y_feed_card_item
FEISHU_THREAD_CARD_SELECTOR=.a11y_feed_card_item
FEISHU_THREAD_PANEL_SELECTOR=.groupDetail_content--ThreadDetailPage
FEISHU_THREAD_PANEL_BODY_SELECTOR=.groupDetailBody
